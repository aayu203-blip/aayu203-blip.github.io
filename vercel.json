{
  "cleanUrls": true,
  "trailingSlash": false,
  "buildCommand": "cd weaver-game && npm install && npm run build",
  "outputDirectory": "weaver-game/.next",
  "installCommand": "cd weaver-game && npm install",
  "framework": "nextjs",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "index, follow"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/weaver",
      "destination": "/weaver-game"
    },
    {
      "source": "/weaver/:path*",
      "destination": "/weaver-game/:path*"
    }
  ]
}
