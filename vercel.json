{
  "version": 2,
  "builds": [
    {
      "src": "weaver-game/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/weaver/(.*)",
      "dest": "/weaver-game/$1"
    },
    {
      "src": "/weaver",
      "dest": "/weaver-game"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "index, follow"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
